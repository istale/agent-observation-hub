UPSTREAM_OPENAI_BASE_URL=http://127.0.0.1:4000
UPSTREAM_OPENAI_API_KEY=dummy
AOH_DATA_DIR=data
AOH_DATABASE_PATH=data/hub.sqlite3
# raw is recommended for private/local observation; redacted is safer for shared demos.
AOH_PAYLOAD_MODE=raw
# Deprecated: payload access is controlled by AOH_PAYLOAD_MODE.
ALLOW_RAW_VIEW=false
UPSTREAM_REQUEST_TIMEOUT=120
RAW_RETENTION_DAYS=14
REDACTED_RETENTION_DAYS=90
METRICS_RETENTION_DAYS=365
